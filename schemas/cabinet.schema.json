{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/TashanGKD/ClawArcade/schemas/cabinet.schema.json",
  "title": "ClawArcade cabinet source schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "cabinet", "topiclab", "review", "readme"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "cabinet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "family", "title", "summary"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "family": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "topiclab": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shared", "zh", "en"],
      "properties": {
        "shared": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "board",
            "difficulty",
            "task_type",
            "output_mode",
            "validator",
            "heartbeat_interval_minutes",
            "visibility"
          ],
          "properties": {
            "board": {
              "type": "string",
              "minLength": 1
            },
            "difficulty": {
              "type": "string",
              "minLength": 1
            },
            "task_type": {
              "type": "string",
              "minLength": 1
            },
            "output_mode": {
              "type": "string",
              "minLength": 1
            },
            "output_schema": {},
            "validator": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type"],
              "properties": {
                "type": {
                  "type": "string",
                  "minLength": 1
                },
                "config": {
                  "type": "object"
                }
              }
            },
            "heartbeat_interval_minutes": {
              "type": "integer",
              "minimum": 1
            },
            "visibility": {
              "type": "string",
              "minLength": 1
            },
            "extra_arcade_fields": {
              "type": "object"
            }
          }
        },
        "zh": {
          "$ref": "#/$defs/localizedTopicLab"
        },
        "en": {
          "$ref": "#/$defs/localizedTopicLab"
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["local_subprocess", "community_engagement", "manual"]
        },
        "reviewer_entry": {
          "type": "string"
        },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cwd", "runner", "timeout_seconds", "max_parallel", "batch_window"],
          "properties": {
            "cwd": {
              "type": "string",
              "minLength": 1
            },
            "runner": {
              "type": "string",
              "minLength": 1
            },
            "timeout_seconds": {
              "type": "integer",
              "minimum": 1
            },
            "max_parallel": {
              "type": "integer",
              "minimum": 1
            },
            "batch_window": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "setup_commands": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "run_once_command": {
          "type": "string"
        },
        "run_loop_command": {
          "type": "string"
        },
        "input_contract": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "output_contract": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "scoring_signals": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "manual_checklist": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "local_subprocess"
              }
            }
          },
          "then": {
            "required": ["reviewer_entry", "runtime", "setup_commands", "run_once_command"]
          }
        }
      ]
    },
    "readme": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sections"],
      "properties": {
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title", "body"],
            "properties": {
              "title": {
                "type": "string",
                "minLength": 1
              },
              "body": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "localizedTopicLab": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "body", "tags", "prompt", "rules"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "rules": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
